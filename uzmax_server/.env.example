# ───────────────────────────────────────────────────────────
#  UzMAX Unified Server — Environment Variables
#  Copy this file to  uzmax_server/.env  and fill in values.
# ───────────────────────────────────────────────────────────

# ── Yandex SpeechKit ────────────────────────────────────────
YANDEX_API_KEY=AQVN_YOUR_YANDEX_API_KEY_HERE
YANDEX_CATALOG_ID=b1g_YOUR_FOLDER_ID_HERE

# ── LLM (OpenRouter — free models available) ────────────────
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_APP_NAME=UzMAX Robot
OPENROUTER_SITE_URL=http://localhost:8000

# ── OR: Use OpenAI instead of OpenRouter ────────────────────
# (comment out the OPENROUTER lines above, uncomment below)
# OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
# OPENAI_MODEL=gpt-4o-mini

# ── Google Gemini (for Face Embeddings) ─────────────────────
GEMINI_API_KEY=AIza_YOUR_GEMINI_KEY_HERE

# ── Face recognition tuning ─────────────────────────────────
FACE_MATCH_THRESHOLD=0.62
FACE_LOG_ALL_COMPARISONS=false
